# aspire_data — environment variable template.
# Copy to .env in your app's working directory. Values stay private; the
# library never logs them and never hardcodes any of them.

# ===== Posit Connect (used by every Connect-backed call) =====
CONNECT_BASE_URL=https://posit.aspire.qa
CONNECT_API_KEY=

# Per-service GUIDs (filled in once per Aspire env)
HANA_API_GUID=
RENDER_API_GUID=
JOBS_API_GUID=
NOTIFY_API_GUID=

# ===== Sports API (Oracle VM FastAPI) =====
SPORTS_API_URL=https://qatar-sports-analytics.duckdns.org
SPORTS_API_KEY=

# ===== SAMS (Aspire Sports Management System) =====
SAMS_BASE_URL=
SAMS_CLIENT_ID=
SAMS_CLIENT_SECRET=

# ===== Hetzner OpenClaw scraper (proxy path is preferred) =====
HETZNER_PROXY_BASE=https://qatar-sports-analytics.duckdns.org/hetzner
HETZNER_PROXY_KEY=

# Direct path — only valid when running on Oracle VM or via SSH tunnel
HETZNER_DIRECT_BASE=
HETZNER_DIRECT_KEY=

# ===== Aiven (cloud Postgres / MySQL) =====
AIVEN_PG_URL=
AIVEN_MYSQL_URL=

# ===== Oracle VM databases (direct connection) =====
ORACLE_MYSQL_URL=mysql://user:pwd@host:3306/dbname
ORACLE_PG_URL=postgres://user:pwd@host:5432/dbname

# ===== SAP HANA direct (only when not using hana-api on Connect) =====
HANA_HOST=
HANA_PORT=30015
HANA_USER=
HANA_PASSWORD=
HDBSQL_PATH=

# ===== MotherDuck (scratch / personal warehouse) =====
MOTHERDUCK_TOKEN=

# ===== Aspire laptop SSL guard =====
# Leave unset on Aspire laptop — truststore handles the corp CA.
# Set to 1 to BYPASS the truststore injection (last-resort only).
ASPIRE_DATA_NO_TRUSTSTORE=
